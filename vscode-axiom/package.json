{
  "name": "vscode-axiom",
  "displayName": "Axiom",
  "description": "Language support for Axiom spec files (.axiom)",
  "version": "0.1.0",
  "publisher": "axiom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RCOLKITT/Axiom"
  },
  "homepage": "https://github.com/RCOLKITT/Axiom#readme",
  "bugs": {
    "url": "https://github.com/RCOLKITT/Axiom/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "axiom",
    "specs",
    "code generation",
    "llm"
  ],
  "activationEvents": [
    "onLanguage:axiom"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "axiom",
        "aliases": [
          "Axiom",
          "axiom"
        ],
        "extensions": [
          ".axiom"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "axiom",
        "scopeName": "source.axiom",
        "path": "./syntaxes/axiom.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Axiom",
      "properties": {
        "axiom.server.path": {
          "type": "string",
          "default": "axiom",
          "description": "Path to the axiom executable"
        },
        "axiom.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server"
        }
      }
    },
    "commands": [
      {
        "command": "axiom.buildSpec",
        "title": "Axiom: Build Current Spec"
      },
      {
        "command": "axiom.verifySpec",
        "title": "Axiom: Verify Current Spec"
      },
      {
        "command": "axiom.restartServer",
        "title": "Axiom: Restart Language Server"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "typescript": "^5.3.2",
    "@vscode/vsce": "^2.22.0"
  }
}
